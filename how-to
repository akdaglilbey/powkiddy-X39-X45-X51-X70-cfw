To compile:
source project/set_env.sh

alsa-lib:
./configure --host=arm-buildroot-linux-uclibcgnueabihf --enable-shared --disable-python --with-configdir=/mnt/card/cfw --with-plugindir=/mnt/card/cfw

configure : see _compile in SDL folder :  ./configure \
    --host=arm-buildroot-linux-uclibcgnueabi \
    --disable-video-opengl \
    --disable-video-x11 \
    --disable-video-wayland \
    --enable-video-fbcon \
    --enable-joystick \
    --enable-audio 
 then make and make install

